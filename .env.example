# Django Settings
# IMPORTANT: Generate a new SECRET_KEY using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-REPLACE-WITH-RANDOM-KEY
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,localhost,127.0.0.1

# Database Settings (for production PostgreSQL)
# Uncomment if using PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://user:password@host:5432/accounting_db

# Static & Media Files (PythonAnywhere)
STATIC_ROOT=/home/yourusername/accounting_acas/staticfiles
STATIC_URL=/static/
MEDIA_ROOT=/home/yourusername/accounting_acas/media
MEDIA_URL=/media/

# CSRF Trusted Origins (for PythonAnywhere)
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Email Settings (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-password

# ============================================
# LOCAL DEVELOPMENT SETUP
# ============================================
# 1. Copy this file to .env
# 2. Generate a new SECRET_KEY (see command above)
# 3. Set these values for development:
#    DEBUG=True
#    ALLOWED_HOSTS=localhost,127.0.0.1
#
# NEVER commit the .env file to version control!
# The .gitignore file already excludes it.
